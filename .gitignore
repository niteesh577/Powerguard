# ── Secrets & credentials ────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.txt

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv ───────────────────────────────────────────────────────────────────────
# Keep uv.lock committed (reproducible installs) — only ignore the cache
.uv/

# ── Build / packaging ─────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checkers / linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Video inputs (large binary files — store in cloud/LFS instead) ────────────
biomechanics-sbd/VIDEOS/INPUTS/
biomechanics-sbd/VIDEOS/OUTPUTS/

# ── Generated analysis outputs (re-creatable from video + code) ───────────────
*_analysis.mp4
*_analysis.json

# ── MediaPipe model weights (auto-downloaded on first run) ────────────────────
*.task

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
